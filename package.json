{
  "name": "0xtools",
  "displayName": "0xTools - Solidity Developer Toolkit",
  "description": "The ultimate Solidity development toolkit — gas analysis, security audits, on-chain inspection, Foundry/Hardhat integration, and more",
  "version": "0.0.5",
  "publisher": "0xshubhs",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.74.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "solidity",
    "smart-contracts",
    "foundry",
    "hardhat",
    "signatures",
    "ethereum",
    "blockchain"
  ],
  "activationEvents": [
    "onLanguage:solidity",
    "workspaceContains:**/*.sol",
    "workspaceContains:foundry.toml",
    "workspaceContains:hardhat.config.js",
    "workspaceContains:hardhat.config.ts"
  ],
  "sideEffects": false,
  "main": "./dist/extension/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": [
          "Solidity",
          "solidity"
        ],
        "extensions": [
          ".sol"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "sigscan.scanProject",
        "title": "Scan Project for Signatures",
        "category": "0xTools"
      },
      {
        "command": "sigscan.startWatching",
        "title": "Start Watching for Changes",
        "category": "0xTools"
      },
      {
        "command": "sigscan.stopWatching",
        "title": "Stop Watching for Changes",
        "category": "0xTools"
      },
      {
        "command": "sigscan.exportSignatures",
        "title": "Export Signatures",
        "category": "0xTools"
      },
      {
        "command": "sigscan.refreshSignatures",
        "title": "Refresh Signatures",
        "category": "0xTools"
      },
      {
        "command": "sigscan.copySignature",
        "title": "Copy Function Signature",
        "category": "0xTools"
      },
      {
        "command": "sigscan.copySelector",
        "title": "Copy Function Selector",
        "category": "0xTools"
      },
      {
        "command": "sigscan.generateABI",
        "title": "Generate ABI from Signatures",
        "category": "0xTools"
      },
      {
        "command": "sigscan.estimateGas",
        "title": "Estimate Gas Costs",
        "category": "0xTools"
      },
      {
        "command": "sigscan.checkContractSize",
        "title": "Check Contract Size",
        "category": "0xTools"
      },
      {
        "command": "sigscan.analyzeComplexity",
        "title": "Analyze Code Complexity",
        "category": "0xTools"
      },
      {
        "command": "sigscan.verifyEtherscan",
        "title": "Verify Against Etherscan",
        "category": "0xTools"
      },
      {
        "command": "sigscan.searchDatabase",
        "title": "Search Signature Database",
        "category": "0xTools"
      },
      {
        "command": "sigscan.generateAllReports",
        "title": "Generate All Analysis Reports",
        "category": "0xTools"
      },
      {
        "command": "sigscan.showGasAnnotations",
        "title": "Show Gas Annotations (Refresh)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.toggleRealtimeAnalysis",
        "title": "Toggle Real-time Gas Analysis",
        "category": "0xTools"
      },
      {
        "command": "sigscan.showStorageLayout",
        "title": "Show Storage Layout Analysis",
        "category": "0xTools",
        "icon": "$(database)"
      },
      {
        "command": "sigscan.showCallGraph",
        "title": "Show Function Call Graph",
        "category": "0xTools",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "sigscan.showDeploymentCost",
        "title": "Show Deployment Cost Estimate",
        "category": "0xTools",
        "icon": "$(rocket)"
      },
      {
        "command": "sigscan.compareWithBranch",
        "title": "Compare Gas with Branch",
        "category": "0xTools",
        "icon": "$(git-compare)"
      },
      {
        "command": "sigscan.showProfilerReport",
        "title": "Show Runtime Profiler Report",
        "category": "0xTools",
        "icon": "$(graph)"
      },
      {
        "command": "sigscan.detectCollisions",
        "title": "Detect Selector Collisions",
        "category": "0xTools"
      },
      {
        "command": "sigscan.checkInterfaces",
        "title": "Check Interface Compliance (ERC20/721/1155)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.suggestOptimizations",
        "title": "Suggest Gas Optimizations",
        "category": "0xTools"
      },
      {
        "command": "sigscan.showCoverage",
        "title": "Show Test Coverage",
        "category": "0xTools"
      },
      {
        "command": "sigscan.analyzeUpgrade",
        "title": "Analyze Upgrade Compatibility",
        "category": "0xTools"
      },
      {
        "command": "sigscan.detectInvariants",
        "title": "Detect Contract Invariants",
        "category": "0xTools"
      },
      {
        "command": "sigscan.analyzeMEV",
        "title": "Analyze MEV Risks",
        "category": "0xTools"
      },
      {
        "command": "sigscan.createGasSnapshot",
        "title": "Create Gas Snapshot",
        "category": "0xTools"
      },
      {
        "command": "sigscan.showGasPricing",
        "title": "Show Live Gas Prices",
        "category": "0xTools"
      },
      {
        "command": "sigscan.lookup4byte",
        "title": "Lookup 4-Byte Selector",
        "category": "0xTools"
      },
      {
        "command": "sigscan.generateTests",
        "title": "Generate Foundry Test Stubs",
        "category": "0xTools"
      },
      {
        "command": "sigscan.openPlayground",
        "title": "Open Contract Playground",
        "category": "0xTools",
        "icon": "$(play)"
      },
      {
        "command": "sigscan.openDashboard",
        "title": "Open Project Dashboard",
        "category": "0xTools",
        "icon": "$(dashboard)"
      },
      {
        "command": "sigscan.detectReentrancy",
        "title": "Detect Reentrancy Vulnerabilities",
        "category": "0xTools"
      },
      {
        "command": "sigscan.detectUncheckedCalls",
        "title": "Detect Unchecked Low-Level Calls",
        "category": "0xTools"
      },
      {
        "command": "sigscan.checkEvents",
        "title": "Check Missing Event Emissions",
        "category": "0xTools"
      },
      {
        "command": "sigscan.checkAccessControl",
        "title": "Check Access Control",
        "category": "0xTools"
      },
      {
        "command": "sigscan.suggestCustomErrors",
        "title": "Suggest Custom Errors (Gas Savings)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.checkNatspec",
        "title": "Check NatSpec Completeness",
        "category": "0xTools"
      },
      {
        "command": "sigscan.forgeRunTest",
        "title": "Run Forge Test",
        "category": "0xTools"
      },
      {
        "command": "sigscan.forgeRunAllTests",
        "title": "Run All Forge Tests",
        "category": "0xTools"
      },
      {
        "command": "sigscan.detectDangerousPatterns",
        "title": "Detect Dangerous Patterns (tx.origin, selfdestruct, delegatecall)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.detectDeFiRisks",
        "title": "Detect DeFi Risks (Oracle, Precision, Approval, Zero-Address, Vault)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.runSlither",
        "title": "Run Slither Analysis",
        "category": "0xTools"
      },
      {
        "command": "sigscan.runMythril",
        "title": "Run Mythril Analysis",
        "category": "0xTools"
      },
      {
        "command": "sigscan.inspectTransaction",
        "title": "Inspect Transaction by Hash",
        "category": "0xTools",
        "icon": "$(search)"
      },
      {
        "command": "sigscan.exploreAddress",
        "title": "Inspect Address (Balance, Code, Proxy)",
        "category": "0xTools",
        "icon": "$(account)"
      },
      {
        "command": "sigscan.viewEvents",
        "title": "View Contract Events",
        "category": "0xTools",
        "icon": "$(list-unordered)"
      },
      {
        "command": "sigscan.readContractState",
        "title": "Read Contract State",
        "category": "0xTools",
        "icon": "$(eye)"
      },
      {
        "command": "sigscan.getTokenBalance",
        "title": "Get ERC20 Token Balance",
        "category": "0xTools"
      },
      {
        "command": "sigscan.castCommand",
        "title": "Run Cast Command",
        "category": "0xTools",
        "icon": "$(terminal)"
      },
      {
        "command": "sigscan.startAnvil",
        "title": "Start Local Anvil Node",
        "category": "0xTools",
        "icon": "$(server-process)"
      },
      {
        "command": "sigscan.stopAnvil",
        "title": "Stop Anvil Node",
        "category": "0xTools"
      },
      {
        "command": "sigscan.runForgeScript",
        "title": "Run Forge Script",
        "category": "0xTools",
        "icon": "$(run)"
      },
      {
        "command": "sigscan.flattenContract",
        "title": "Flatten Contract",
        "category": "0xTools"
      },
      {
        "command": "sigscan.insertSnippet",
        "title": "Insert Solidity Snippet",
        "category": "0xTools",
        "icon": "$(symbol-snippet)"
      },
      {
        "command": "sigscan.traceTenderly",
        "title": "Trace Transaction (Tenderly)",
        "category": "0xTools"
      },
      {
        "command": "sigscan.simulateFork",
        "title": "Simulate on Fork",
        "category": "0xTools",
        "icon": "$(debug-alt)"
      },
      {
        "command": "sigscan.stopFork",
        "title": "Stop Fork Simulation",
        "category": "0xTools"
      },
      {
        "command": "sigscan.runHardhatTask",
        "title": "Run Hardhat Task",
        "category": "0xTools"
      },
      {
        "command": "sigscan.hardhatCompile",
        "title": "Hardhat: Compile",
        "category": "0xTools"
      },
      {
        "command": "sigscan.hardhatTest",
        "title": "Hardhat: Run Tests",
        "category": "0xTools"
      }
    ],
    "configuration": {
      "title": "0xTools",
      "properties": {
        "sigscan.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan for signatures when files change"
        },
        "sigscan.scanInterval": {
          "type": "number",
          "default": 5,
          "description": "Scan interval in seconds"
        },
        "sigscan.outputFormats": {
          "type": "array",
          "default": [
            "txt",
            "json"
          ],
          "description": "Output formats to generate",
          "items": {
            "type": "string",
            "enum": [
              "txt",
              "json",
              "csv",
              "md"
            ]
          }
        },
        "sigscan.contractDirs": {
          "type": "array",
          "default": [
            "src",
            "contracts"
          ],
          "description": "Directories to scan for contracts"
        },
        "sigscan.excludeInternal": {
          "type": "boolean",
          "default": true,
          "description": "Exclude internal functions from output"
        },
        "sigscan.excludePrivate": {
          "type": "boolean",
          "default": true,
          "description": "Exclude private functions from output"
        },
        "sigscan.generateABI": {
          "type": "boolean",
          "default": true,
          "description": "Automatically generate ABI files alongside signatures"
        },
        "sigscan.estimateGas": {
          "type": "boolean",
          "default": true,
          "description": "Include gas estimation in reports"
        },
        "sigscan.checkSize": {
          "type": "boolean",
          "default": true,
          "description": "Check contract size against 24KB limit"
        },
        "sigscan.analyzeComplexity": {
          "type": "boolean",
          "default": false,
          "description": "Analyze code complexity metrics"
        },
        "sigscan.realtimeAnalysis": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time gas analysis and inline annotations as you type"
        },
        "sigscan.realtime.solcIdleMs": {
          "type": "number",
          "default": 10000,
          "minimum": 0,
          "maximum": 60000,
          "description": "Run accurate solc gas estimation after this many milliseconds of no typing (0 = disabled, 10000 = 10 seconds recommended)"
        },
        "sigscan.gas.solcOnly": {
          "type": "boolean",
          "default": true,
          "description": "Use only solc compiler for gas estimates (no heuristic fallback). Recommended for accuracy."
        },
        "sigscan.etherscanApiKey": {
          "type": "string",
          "default": "",
          "description": "Etherscan API key for contract verification"
        },
        "sigscan.runnerBinaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the sigscan-runner binary. Leave empty for auto-discovery (bundled, PATH, or workspace)."
        },
        "sigscan.logLevel": {
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Log level for 0xTools output channel"
        },
        "sigscan.preferRunner": {
          "type": "boolean",
          "default": true,
          "description": "Use sigscan-runner (EVM execution) as the primary gas backend when available. Disable to use forge/solc instead."
        },
        "sigscan.defaultChain": {
          "type": "string",
          "default": "ethereum",
          "enum": ["ethereum", "sepolia", "polygon", "arbitrum", "optimism", "bsc", "base", "avalanche"],
          "description": "Default chain for on-chain operations (tx inspect, address lookup, events)"
        },
        "sigscan.rpc.customEndpoints": {
          "type": "object",
          "default": {},
          "description": "Custom RPC endpoints per chain. Example: { \"ethereum\": \"https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY\" }"
        },
        "sigscan.tenderly.accessKey": {
          "type": "string",
          "default": "",
          "description": "Tenderly API access key for transaction simulation"
        },
        "sigscan.tenderly.accountSlug": {
          "type": "string",
          "default": "",
          "description": "Tenderly account slug"
        },
        "sigscan.tenderly.projectSlug": {
          "type": "string",
          "default": "",
          "description": "Tenderly project slug"
        }
      }
    },
    "notebooks": [
      {
        "type": "sigscan-notebook",
        "displayName": "0xTools Notebook",
        "selector": [
          { "filenamePattern": "*.sigscan" }
        ]
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "sigScanExplorer",
          "name": "Contract Signatures",
          "when": "sigscan:hasContracts"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sigscan.refreshSignatures",
          "when": "view == sigScanExplorer",
          "group": "navigation",
          "icon": "$(refresh)"
        }
      ],
      "commandPalette": [
        {
          "command": "sigscan.scanProject",
          "when": "sigscan:hasContracts"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "postinstall": "node scripts/postinstall.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cli": "node dist/cli/index.js",
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/glob": "^9.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.6",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^9.4.1",
    "glob": "^8.0.3",
    "js-sha3": "^0.8.0",
    "semver": "^7.7.3",
    "solc": "^0.8.28"
  },
  "bin": {
    "sigscan": "./dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xshubhs/0xtools.git"
  },
  "bugs": {
    "url": "https://github.com/0xshubhs/0xtools/issues"
  },
  "homepage": "https://github.com/0xshubhs/0xtools#readme",
  "author": {
    "name": "0xshubhs",
    "url": "https://github.com/0xshubhs"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/badge/License-MIT-yellow.svg",
